{
  "manifest_version": 3,
  "name": "TikTok Shop Bulk Creator Messenger",
  "version": "1.0.0",
  "description": "Select creators on TikTok Shop Partner Center and send them messages in bulk with safe pacing.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://partner.us.tiktokshop.com/*",
    "https://partner.tiktokshop.com/*",
    "https://partner.eu.tiktokshop.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bulk Creator Messenger"
  },
  "content_scripts": [
    {
      "matches": [
        "https://partner.us.tiktokshop.com/affiliate-cmp/creator*",
        "https://partner.tiktokshop.com/affiliate-cmp/creator*",
        "https://partner.eu.tiktokshop.com/affiliate-cmp/creator*"
      ],
      "js": ["finder-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://partner.us.tiktokshop.com/affiliate-cmp/creator*",
        "https://partner.tiktokshop.com/affiliate-cmp/creator*",
        "https://partner.eu.tiktokshop.com/affiliate-cmp/creator*"
      ],
      "js": ["finder.js"],
      "css": ["finder.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://partner.us.tiktokshop.com/partner/im*",
        "https://partner.tiktokshop.com/partner/im*",
        "https://partner.eu.tiktokshop.com/partner/im*"
      ],
      "js": ["chat-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://partner.us.tiktokshop.com/partner/im*",
        "https://partner.tiktokshop.com/partner/im*",
        "https://partner.eu.tiktokshop.com/partner/im*"
      ],
      "js": ["chat.js"],
      "run_at": "document_idle"
    }
  ]
}
